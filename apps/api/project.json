{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["prisma-generate"],
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project apps/api/tsconfig.app.json && node -e \"const fs=require('fs');const d='dist/apps/api/generated';try{fs.rmSync(d,{recursive:true})}catch(e){};fs.cpSync('apps/api/src/generated',d,{recursive:true});\""
      },
      "outputs": ["{workspaceRoot}/dist/apps/api"]
    },
    "serve": {
      "dependsOn": ["prisma-generate"],
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project apps/api/tsconfig.app.json apps/api/src/main.ts"
      },
      "configurations": {}
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate --schema=apps/api/prisma/schema.prisma"
      }
    },
    "prisma-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate dev --schema=apps/api/prisma/schema.prisma"
      }
    }
  }
}
